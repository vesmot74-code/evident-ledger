  "db_name": "PostgreSQL",
  "query": "\n        SELECT\n            tp.name AS plan_name,\n            tp.tsa_mode,\n            tp.server_backup,\n            tp.history_recovery,\n            tp.identity_enabled,\n            tp.monthly_commits_limit,\n            tp.monthly_tsa_limit\n        FROM accounts a\n        JOIN tariff_plans tp ON tp.plan_id = a.tariff_plan_id\n        WHERE a.account_id = $1\n        ",
