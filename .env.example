# Evident Ledger — production / pilot environment template
#
# Copy to `.env` and replace placeholders. Never commit `.env`.
# Startup panics if required Paddle variables are missing (non-test builds).

# --- Database (required) ---
DATABASE_URL=postgresql://user:password@localhost:5432/evident_ledger

# Integration tests only — must point at a dedicated test DB, never production:
# TEST_DATABASE_URL=postgres://user:password@localhost:5432/evident_ledger_test

# --- Paddle Billing (required at startup) ---
# Server-side API key (Developer Tools → Authentication). Keep secret.
PADDLE_API_KEY=pdl_sdbx_replace_me
# Webhook endpoint secret from the notification destination settings.
PADDLE_WEBHOOK_SECRET=pdl_ntfset_replace_me
# Public client-side token for Paddle.js overlay (never use PADDLE_API_KEY here).
PADDLE_CLIENT_TOKEN=test_replace_me
# Optional. Default: https://api.paddle.com
# Sandbox: https://sandbox-api.paddle.com
# PADDLE_API_BASE_URL=https://sandbox-api.paddle.com

# --- Proxy / TLS awareness ---
# Set true only behind a trusted reverse proxy that sets X-Forwarded-For / X-Real-IP.
# TRUST_PROXY_HEADERS=false

# --- Backups (optional) ---
# Directory for server-side backup artifacts. Defaults to ~/.evident/backups when unset.
# EVIDENT_BACKUP_DIR=/var/lib/evident/backups

# --- Development only (must be unset / false in production) ---
# Enables POST /account/dev/change-plan and disables Secure session cookies.
# DEV_MODE=true
# APP_ENV=development
