DATABASE_URL=postgresql://user:password@localhost:5433/database
# Integration tests only — must point at ledger_test, never the server DB:
TEST_DATABASE_URL=postgres://ledger:ledger@localhost:5433/ledger_test
PADDLE_WEBHOOK_SECRET=change-me-in-production
# Public client-side token for Paddle.js (Developer Tools → Authentication). Never use PADDLE_API_KEY here.
PADDLE_CLIENT_TOKEN=test_your_client_side_token
